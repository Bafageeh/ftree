{
  "expo": {
    "name": "شجرة النسب الشريف",
    "slug": "shajara",
    "version": "1.0.4",
    "orientation": "portrait",
    "scheme": "shajara",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1E7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sa.pm.shajara"
    },
    "android": {
      "package": "sa.pm.shajara",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#123E2A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://shajara.pm.sa/api/v1"
    }
  }
}
